# ============ 网页划线对话插件 · 后端配置 ============
# 复制本文件为 .env 后填写：cp .env.example .env

# 【必填才能用真实 AI】CodeBuddy API Key
# 申请地址：https://www.codebuddy.cn  → 个人中心 / API 密钥
# 没有也行：后端会自动进入「演示模式」（模拟回复），用来验收划线→对话的交互闭环
CODEBUDDY_API_KEY=

# 可选：使用的模型（默认 hy3；本账户不支持 claude-sonnet-4，会报 400）
# 可选值：auto / hy3 / glm-5.2 / kimi-k2.x / deepseek-v4-* 等
CODEBUDDY_MODEL=hy3

# 后端监听端口
PORT=3000

# 【重要】官方 codebuddy CLI 启动会起 prewarm 本地 server，端口由 SERVER__PORT 控制。
# 若该端口被本机其他程序（如 WorkBuddy 桌面应用）占用，CLI 会 EADDRINUSE 卡死（表现为一直转圈/无回答）。
# 遇到端口冲突，在这里固定一个空闲端口（如 40123）并重启后端；
# 若系统环境变量里已残留旧 SERVER__PORT，启动时用 `SERVER__PORT=40123 npm start` 显式覆盖。
# SERVER__PORT=40123

# CORS 允许的来源。开发期用 * 即可（浏览器插件从 chrome-extension:// 跨域访问本机）
ALLOWED_ORIGIN=*

# 可选：托管模式心跳宽限（毫秒）。仅当后端由 webchat://start 协议拉起(自动设 WEBCHAT_MANAGED=1)时生效。
# 后端靠扩展的周期性心跳续命：浏览器开着→心跳不断→后端存活；浏览器关→心跳断→超过宽限后自退。
# 默认 150000（2.5 分钟），覆盖扩展服务工作线程的闹钟节流。一般无需改动。
# HEARTBEAT_TTL=150000

# 可选：空闲自动退出（分钟）。任何请求都会重置计时；连续该时长无请求则后端自退。默认 30。
# IDLE_TIMEOUT_MIN=30
